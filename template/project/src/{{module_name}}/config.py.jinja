from __future__ import annotations

from pydantic_settings import BaseSettings, SettingsConfigDict


class {{ env_prefix.title().replace('_', '') }}Config(BaseSettings):
    """Environment-driven configuration for {{ package_name }}.

    All env vars are prefixed with {{ env_prefix }}_ (e.g., {{ env_prefix }}_ENDPOINT).
    """

    model_config = SettingsConfigDict(
        env_prefix="{{ env_prefix }}_",
        env_file=".env",
        env_file_encoding="utf-8",
    )

    # Connection
    endpoint: str = ""
    bearer_token: str = ""
    timeout: int = 30
    ssl_verify: bool = True

    # Schema source selection
    schema_source: str = "auto"
    schema_sdl: str = ""
    schema_ttl: int = 300

    # Behavior
    allow_mutations: bool = False

    # HTTP server
    http_host: str = "0.0.0.0"
    http_port: int = 8000

    # Security
    max_query_depth: int = 10
    rate_limit: str = "100/minute"
