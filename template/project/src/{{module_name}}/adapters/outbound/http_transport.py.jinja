from __future__ import annotations

import logging
from typing import Any

import httpx

from {{ module_name }}.domain.models import ErrorClass, QueryResult

logger = logging.getLogger(__name__)


class HttpTransport:
    """Outbound adapter: sends GraphQL queries over HTTP using httpx."""

    def __init__(
        self,
        endpoint: str,
        headers: dict[str, str] | None = None,
        timeout: int = 30,
    ) -> None:
        self._endpoint = endpoint
        self._client = httpx.Client(
            headers=headers or {},
            timeout=timeout,
        )

    def execute(
        self,
        query: str,
        variables: dict[str, Any] | None = None,
    ) -> QueryResult:
        """Send a GraphQL query and return typed result."""
        body: dict[str, Any] = {"query": query}
        if variables:
            body["variables"] = variables
        return self.post_raw(body)

    def post_raw(self, body: dict[str, Any]) -> QueryResult:
        """Send arbitrary POST body, return typed result."""
        try:
            response = self._client.post(self._endpoint, json=body)
            response.raise_for_status()
            data = response.json()
        except (httpx.HTTPError, ValueError) as exc:
            logger.error("Transport error: %s", exc)
            return QueryResult(
                error_class=ErrorClass.TRANSPORT,
                errors=[{"message": str(exc)}],
            )

        errors = data.get("errors", [])
        error_class = ErrorClass.GRAPHQL if errors else ErrorClass.OK
        return QueryResult(
            data=data.get("data"),
            errors=errors,
            error_class=error_class,
        )

    def close(self) -> None:
        """Close the underlying HTTP client."""
        self._client.close()
