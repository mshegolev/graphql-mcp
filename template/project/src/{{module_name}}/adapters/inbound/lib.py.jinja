"""Library face — primary inbound adapter for programmatic use."""

from __future__ import annotations

import atexit
import logging
from typing import TYPE_CHECKING, Any

from {{ module_name }}.config import {{ env_prefix.title().replace('_', '') }}Config
from {{ module_name }}.domain.models import QueryResult, SchemaSummary
from {{ module_name }}.domain.schema_service import SchemaService
from {{ module_name }}.adapters.outbound.http_transport import HttpTransport

if TYPE_CHECKING:
    from {{ module_name }}.ports.transport import GraphQLTransport

logger = logging.getLogger(__name__)


class GraphQLClient:
    """Synchronous GraphQL client — the primary lib-face entry point.

    Usage::

        from {{ module_name }} import GraphQLClient

        with GraphQLClient.from_env() as client:
            result = client.query("{ hello }")
    """

    def __init__(
        self,
        schema_service: SchemaService,
        transport: GraphQLTransport | None = None,
        config: {{ env_prefix.title().replace('_', '') }}Config | None = None,
    ) -> None:
        self._schema_service = schema_service
        self._transport = transport
        self._config = config or {{ env_prefix.title().replace('_', '') }}Config()
        self._closed = False

    @classmethod
    def from_env(cls) -> GraphQLClient:
        """Create a client configured from environment variables."""
        config = {{ env_prefix.title().replace('_', '') }}Config()
        headers = {}
        if config.bearer_token:
            headers["Authorization"] = f"Bearer {config.bearer_token}"

        transport = HttpTransport(
            endpoint=config.endpoint,
            headers=headers,
            timeout=config.timeout,
        )
        service = SchemaService(sources=[], ttl_seconds=config.schema_ttl)
        client = cls(schema_service=service, transport=transport, config=config)
        atexit.register(client.close)
        return client

    def query(self, query: str, variables: dict[str, Any] | None = None) -> QueryResult:
        """Execute a GraphQL query."""
        if self._transport is None:
            raise RuntimeError("No transport configured")
        return self._transport.execute(query, variables)

    def introspect(self) -> SchemaSummary:
        """Return schema summary from the resolved schema."""
        schema = self._schema_service.resolve()
        from graphql import build_schema

        gql_schema = build_schema(schema.sdl)
        query_type = gql_schema.query_type
        fields = list(query_type.fields.keys()) if query_type else []
        return SchemaSummary(query_fields=fields)

    def refresh_schema(self) -> None:
        """Invalidate schema cache and re-resolve."""
        self._schema_service.invalidate()

    def close(self) -> None:
        """Close transport resources."""
        if self._closed:
            return
        self._closed = True
        if self._transport and hasattr(self._transport, "close"):
            self._transport.close()

    def __enter__(self) -> GraphQLClient:
        return self

    def __exit__(self, *args: object) -> None:
        self.close()
