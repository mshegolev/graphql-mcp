[run]
source = src/
branch = True
omit = 
    */tests/*
    */test_*
    */conftest.py
    */__pycache__/*
    */benchmarks/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

show_missing = True
skip_covered = False
precision = 2

[html]
directory = htmlcov

[xml]
output = coverage.xml